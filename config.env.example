# ESP32 sensor node
ESP32_SENSOR_HOST=your_esp32_sensor_ip

# LED matrix ESP32
ESP32_LED_HOST=your_led_matrix_ip
ESP32_LED_KEY=your_led_api_key

# flower-app
PORT=5566

# WiFi + ESPHome (used to generate esp32-sensor/secrets.yaml)
WIFI_SSID=your_wifi_ssid
WIFI_PASSWORD=your_wifi_password
ESP32_API_KEY=your_esphome_api_key
ESP32_OTA_PASSWORD=your_ota_password
